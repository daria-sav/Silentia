  entries:
  - profile: {fileID: 11400000, guid: 317ef33424953e4448cf227047c63027, type: 2}
    introText: 'This is Manipura.

      Fire lives within her. She moves fast, dashes
      forward and turns hesitation into action.'
  - profile: {fileID: 11400000, guid: 317ef33424953e4448cf227047c63027, type: 2}
